# ============================================================
# SMID 6.1 - Identidad y Acceso : variables de entorno
# Cierra DT-2: ningun secreto vive en archivos versionados.
# Genere el secreto HS256 (minimo 256 bits) con:
#   openssl rand -base64 48
# La clave debe coincidir byte a byte con la del Gateway.
# ============================================================
JWT_SECRET=
JWT_KID=smid-2026-06
JWT_ISSUER=smid-auth
JWT_AUDIENCE=smid-servicios
JWT_EXPIRATION_MS=28800000
JWT_REFRESH_EXPIRATION_MS=86400000

DB_URL=jdbc:mysql://localhost:3306/db_auth?useSSL=false&allowPublicKeyRetrieval=true&connectionTimeZone=UTC
DB_USER=smid_auth
DB_PASSWORD=

RBAC_ENABLED=true

# Solo para perfiles local|dev (activa el sembrador de datos):
SPRING_PROFILES_ACTIVE=local
SEED_PASSWORD=Smid.Local.2026
